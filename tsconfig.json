{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": "./src",
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "src/*": ["./*"],
      "@ant/*": ["../stubs/@ant/*"],
      "@anthropic-ai/mcpb": ["../stubs/@anthropic-ai/mcpb"],
      "react/compiler-runtime": ["../stubs/react/compiler-runtime"]
    }
  },
  "include": ["src/**/*", "stubs/**/*"],
  "exclude": ["node_modules", "dist"]
}
